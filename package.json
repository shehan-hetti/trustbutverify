{
  "name": "trustbutverify",
  "version": "1.0.0",
  "description": "Browser extension to track copy activities on LLM/Gen AI websites",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc && vite build && npm run postbuild",
    "postbuild": "node scripts/postbuild.js",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "copy-tracking",
    "llm",
    "genai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "vite": "^6.4.1",
    "vite-plugin-static-copy": "^3.1.4"
  },
  "dependencies": {
    "text-readability-ts": "^1.0.11"
  }
}
