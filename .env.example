# TrustButVerify Extension — Environment Configuration
# Copy this file to .env before building:
#
#   cp .env.example .env
#
# Then set VITE_BACKEND_URL to the address of your deployed
# trustbutverify-backend instance.
# See: https://github.com/shehan-hetti/trustbutverify-backend

# Backend API base URL (no trailing slash)
# Local dev:  https://localhost
# Production: https://api.trustbutverify.dev
VITE_BACKEND_URL=https://api.trustbutverify.dev
